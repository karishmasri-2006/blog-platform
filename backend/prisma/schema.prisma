generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  name      String
  email     String    @unique
  password  String
  createdAt DateTime  @default(now())

  posts     Post[]
  comments  Comment[]
}

model Post {
  id        String    @id @default(cuid())
  title     String
  content   String
  createdAt DateTime  @default(now())

  authorId  String
  author    User      @relation(fields: [authorId], references: [id])

  comments  Comment[]
}

model Comment {
  id        String    @id @default(cuid())
  text      String
  createdAt DateTime  @default(now())

  userId    String
  user      User      @relation(fields: [userId], references: [id])

  postId    String
  post      Post      @relation(fields: [postId], references: [id])
}